# Postgres connection. docker-compose sets this for the `api` service automatically;
# this value is for running the app directly against a local Postgres.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/research

# OpenAI — required for the LLM agents. (Embeddings run locally, so no key on that path.)
OPENAI_API_KEY=sk-...

# Tavily — required for the web_search tool.
TAVILY_API_KEY=tvly-...

# LangSmith — optional, enables tracing.
LANGSMITH_API_KEY=

# Embedding model: local sentence-transformers, 384-dim. No API key required.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Hard cap on the critic self-correction loop.
MAX_ITERATIONS=2
