# Postgres connection. docker-compose sets this for the `api` service automatically;
# this value is for running the app directly against a local Postgres.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/research

# OpenAI — required for the LLM agents. (Embeddings run locally, so no key on that path.)
OPENAI_API_KEY=sk-...

# Tavily — required for the web_search tool.
TAVILY_API_KEY=tvly-...

# LangSmith — optional. Set a key to enable tracing (per-agent spans, token usage, latency).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=autonomous-research-analyst

# Embedding model: local sentence-transformers, 384-dim. No API key required.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Hard cap on the critic self-correction loop.
MAX_ITERATIONS=2

# Reliability (PRD §12): per-call LLM timeout (seconds) and retry count for transient errors.
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

# Phase 6: Authentication (plan 6.2).
# Required — generate with: python -c 'import secrets; print(secrets.token_urlsafe(64))'
# Do NOT commit a real secret.
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Set to true in production (HTTPS only). false is required for local http://localhost dev —
# Secure cookies are dropped by the browser on non-HTTPS, silently breaking login.
COOKIE_SECURE=false

# Rate limiting (slowapi). On by default; per-endpoint limits are in app/api/ratelimit.py.
# Set to false to disable entirely (e.g. load testing).
RATE_LIMIT_ENABLED=true
